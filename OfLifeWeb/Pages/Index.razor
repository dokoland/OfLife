@page "/"

@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using OfLife
@inject IJSRuntime JsRuntime;

<div id="canvasHolder" style="position: fixed; width: 100%; height: 100%">
    <BECanvas Width="600" Height="400" @ref="CanvasRef"></BECanvas>
</div>

@code {
    private static double _scale = 4.0;
    private static MapBuilder _mapBuilder = A.Map
                .WithWidth(400)
                .WithHeight(200)
                .WithPentominoR();
    private static Game _game = new Game(_mapBuilder);

    private Canvas2DContext ctx;
    protected BECanvasComponent CanvasRef;
    private DateTime LastRender;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        this.ctx = await CanvasRef.CreateCanvas2DAsync();
        await JsRuntime.InvokeAsync<object>("initRenderJS", DotNetObjectReference.Create(this));
        await base.OnInitializedAsync();

        await this.ctx.BeginBatchAsync();
        await ClearCanvas();
        await this.ctx.EndBatchAsync();
    }

    [JSInvokable]
    public void ResizeInBlazor(double width, double height)
    {
        //=> _game.Resize(width, height);
    }

    [JSInvokable]
    public async ValueTask RenderInBlazor(float timeStamp)
    {
        double fps = 1.0 / (DateTime.Now - LastRender).TotalSeconds;
        LastRender = DateTime.Now;

        await this.ctx.BeginBatchAsync();

        var (born, died) = _game.Cycle();

        await this.ctx.SetFillStyleAsync("#003366");
        await this.ctx.FillRectAsync(10, 2, 120, 16);

        await this.ctx.SetFillStyleAsync("#FFFFFF");
        await this.ctx.SetFontAsync("16px consolas");
        await this.ctx.FillTextAsync($"FPS: {fps:0.000}", 10, 15);
        await this.ctx.SetStrokeStyleAsync("#FFFFFF");

        await this.ctx.SetFillStyleAsync("#003366");
        foreach (var cell in died)
        {
            await DrawRect(cell);
        }

        await this.ctx.SetFillStyleAsync("#FFFFFF");
        foreach (var cell in born)
        {
            await DrawRect(cell);
        }

        await this.ctx.EndBatchAsync();

    }

    private async Task DrawRect((int, int) cell)
    {
        await this.ctx.FillRectAsync(cell.Item1 * _scale, cell.Item2 * _scale, _scale, _scale);
    }

    private async Task ClearCanvas()
    {
        await this.ctx.ClearRectAsync(0, 0, _mapBuilder.Width * _scale, _mapBuilder.Height * _scale);
        await this.ctx.SetFillStyleAsync("#003366");
        await this.ctx.FillRectAsync(0, 0, _mapBuilder.Width * _scale, _mapBuilder.Height * _scale);
    }
}